{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-feedback.sh\"",
            "timeout": 45,
            "statusMessage": "Checking for new feedback..."
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-feedback.sh\"",
            "timeout": 45,
            "statusMessage": "Re-checking feedback after context reset..."
          }
        ]
      }
    ]
  }
}
